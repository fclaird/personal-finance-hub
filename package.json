{
  "name": "personal-finance-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Umbrella repo for Finance Hub (local personal finance dashboard)",
  "scripts": {
    "dev": "npm run dev --prefix apps/finance-hub",
    "build": "npm run build --prefix apps/finance-hub",
    "start": "npm run start --prefix apps/finance-hub",
    "test": "npm run test --prefix apps/finance-hub",
    "lint": "npm run lint --prefix apps/finance-hub",
    "check:api-routes": "node apps/finance-hub/scripts/check-api-routes.mjs",
    "desktop:dev": "npm run desktop:dev --prefix apps/finance-hub",
    "desktop:dist": "npm run desktop:dist --prefix apps/finance-hub"
  }
}
